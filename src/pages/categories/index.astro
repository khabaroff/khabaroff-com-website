---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCategorySlug, getCategoryName, categoryMap } from '../../utils/categories';

const allPosts = await getCollection('posts');
const posts = allPosts.filter(post => !post.data.draft);

const categoriesWithCounts = Object.keys(categoryMap).map(categoryRu => {
  const slug = getCategorySlug(categoryRu);
  const count = posts.filter(post => post.data.category === categoryRu).length;
  return {
    slug,
    name: getCategoryName(slug),
    count
  };
}).filter(cat => cat.count > 0);
---

<BaseLayout title="Категории" description="Все категории блога">
  <nav class="breadcrumb">
    <a href="/">← На главную</a>
  </nav>

  <h1>Категории</h1>
  <p class="page-description">Все статьи, организованные по категориям</p>

  <div class="categories-grid">
    {categoriesWithCounts.map(category => (
      <a href={`/categories/${category.slug}`} class="category-card">
        <h2>{category.name}</h2>
        <p class="count">{category.count} {category.count === 1 ? 'пост' : category.count < 5 ? 'поста' : 'постов'}</p>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .breadcrumb {
    padding: 2rem 0;
  }

  .breadcrumb a {
    color: var(--color-pink);
    text-decoration: none;
    font-weight: 600;
    transition: opacity 0.2s;
  }

  .breadcrumb a:hover {
    opacity: 0.7;
  }

  h1 {
    margin-bottom: 0.5rem;
  }

  .page-description {
    color: #666;
    margin-bottom: 3rem;
    font-size: 1.1rem;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
  }

  .category-card {
    background: var(--color-bg);
    border: 2px solid #f0f0f0;
    border-radius: 12px;
    padding: 2rem;
    text-decoration: none;
    transition: all 0.3s ease;
    display: block;
  }

  .category-card:hover {
    border-color: var(--color-pink);
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(237, 110, 172, 0.2);
  }

  .category-card h2 {
    color: var(--color-pink);
    margin: 0 0 0.5rem 0;
    font-size: 1.5rem;
  }

  .category-card .count {
    color: #666;
    margin: 0;
    font-size: 0.95rem;
  }
</style>
