---
import { getCollection } from 'astro:content';
import PostLayout from '../layouts/PostLayout.astro';
import TwoColumns from '../components/TwoColumns.astro';
import ImageWide from '../components/ImageWide.astro';
import Callout from '../components/Callout.astro';
import VideoEmbed from '../components/VideoEmbed.astro';
import QuoteBlock from '../components/QuoteBlock.astro';
import BookCard from '../components/BookCard.astro';
import { getTagSlug } from '../utils/tags';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts
    .filter(post => !post.data.draft)
    .map(post => ({
      params: { slug: post.slug },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<PostLayout title={post.data.title} description={post.data.description}>
  <main>
    <article class="article">
      <div class="container">
        <div class="article-header">
          {post.data.cover && (
            <div class="article-cover">
              <img src={post.data.cover} alt={post.data.coverAlt || post.data.title} />
            </div>
          )}

          <div class="article-meta">
            <span class="article-type">{post.data.type}</span>
          </div>

          <h1 class="article-title">{post.data.title}</h1>

          <div class="article-info">
            <time class="article-date">
              {post.data.date.toLocaleDateString('ru-RU', {
                year: 'numeric',
                month: 'long',
                day: 'numeric'
              })}
            </time>

            {post.data.tags.length > 0 && (
              <div class="article-tags">
                {post.data.tags.map((tag: string) => (
                  <a href={`/tags/${getTagSlug(tag)}/`} class="tag">#{tag}</a>
                ))}
              </div>
            )}
          </div>
        </div>

        <div class="prose">
          <Content components={{
            TwoColumns,
            ImageWide,
            Callout,
            VideoEmbed,
            QuoteBlock,
            BookCard,
          }} />
        </div>
      </div>
    </article>
  </main>
</PostLayout>

<style>
  .article {
    background: var(--color-white);
    padding: 48px 0 80px;
  }
  @media (min-width: 768px) { .article { padding: 64px 0 80px; } }

  .article-header {
    margin-bottom: 48px;
  }
  .article-cover {
    width: 100%;
    aspect-ratio: 2 / 1;
    overflow: hidden;
    border-radius: 8px;
    margin-bottom: 32px;
  }
  .article-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .article-meta {
    margin-bottom: 16px;
  }
  .article-type {
    background: var(--color-primary);
    color: white;
    font-size: 12px;
    font-weight: 500;
    padding: 8px 16px;
    border-radius: 20px;
  }
  .article-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 36px;
    line-height: 1.1;
    color: var(--color-text);
    margin-bottom: 16px;
  }
  @media (min-width: 768px) { .article-title { font-size: 48px; } }
  @media (min-width: 1024px) { .article-title { font-size: 64px; } }
  .article-info {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .article-date {
    color: var(--color-text-muted);
    font-size: 13px;
    font-weight: 500;
  }
  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .tag {
    background: var(--color-background-alt);
    color: var(--color-text-secondary);
    font-size: 12px;
    padding: 4px 12px;
    border-radius: 20px;
    transition: all 0.2s;
  }
  .tag:hover {
    background: var(--color-accent-green);
    color: white;
  }

  /* Prose */
  .prose {
    max-width: 720px;
  }
  .prose :global(h1) {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 30px;
    line-height: 1.2;
    color: var(--color-text);
    margin-bottom: 32px;
  }
  @media (min-width: 768px) {
    .prose :global(h1) { font-size: 36px; }
  }
  .prose :global(h2) {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 24px;
    line-height: 1.3;
    color: var(--color-text);
    margin-top: 48px;
    margin-bottom: 24px;
  }
  @media (min-width: 768px) {
    .prose :global(h2) { font-size: 30px; }
  }
  .prose :global(h3) {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 20px;
    line-height: 1.4;
    color: var(--color-text);
    margin-top: 32px;
    margin-bottom: 16px;
  }
  @media (min-width: 768px) {
    .prose :global(h3) { font-size: 24px; }
  }
  .prose :global(p) {
    color: var(--color-text-secondary);
    font-size: 18px;
    line-height: 1.625;
    margin-bottom: 24px;
  }
  .prose :global(a) {
    color: var(--color-primary);
    transition: opacity 0.2s;
  }
  .prose :global(a:hover) { opacity: 0.7; }
  .prose :global(ul) {
    list-style-type: disc;
    padding-left: 24px;
    margin-bottom: 24px;
  }
  .prose :global(ol) {
    list-style-type: decimal;
    padding-left: 24px;
    margin-bottom: 24px;
  }
  .prose :global(li) {
    color: var(--color-text-secondary);
    font-size: 18px;
    line-height: 1.625;
    margin-bottom: 8px;
  }
  .prose :global(blockquote) {
    border-left: 4px solid var(--color-accent-green);
    padding-left: 24px;
    padding-top: 8px;
    padding-bottom: 8px;
    margin-bottom: 24px;
    background: var(--color-background);
    border-radius: 0 6px 6px 0;
  }
  .prose :global(code) {
    background: #f3f4f6;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 14px;
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Consolas, monospace;
  }
  .prose :global(pre) {
    background: #111827;
    color: #f9fafb;
    padding: 16px;
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: 24px;
  }
  .prose :global(pre code) {
    background: none;
    padding: 0;
  }
  .prose :global(img) {
    width: 100%;
    border-radius: 8px;
    margin: 32px 0;
  }
</style>
