---
import { getCollection } from 'astro:content';
import Layout from '../layouts/BaseLayout.astro';
import TwoColumns from '../components/TwoColumns';
import ImageWide from '../components/ImageWide';
import Callout from '../components/Callout';
import HeroImage from '../components/HeroImage';
import VideoEmbed from '../components/VideoEmbed';
import QuoteBlock from '../components/QuoteBlock';
import StatsGrid from '../components/StatsGrid';
import LinkList from '../components/LinkList';
import BookCard from '../components/BookCard';
import PostHeader from '../components/PostHeader';
import RelatedPosts from '../components/RelatedPosts.astro';
import Calendar from '../components/Calendar';
import { getCategorySlug } from '../utils/categories';
import { getTagSlug } from '../utils/tags';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts
    .filter(post => !post.data.draft)
    .map(post => ({
      params: { slug: post.slug },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const categorySlug = getCategorySlug(post.data.category);
---

<Layout title={post.data.title}>
  <!-- Header -->
  <header class="bg-white border-b border-gray-200">
    <div class="max-w-[1440px] mx-auto px-4 md:px-8 lg:px-30 py-5 flex items-center justify-between flex-wrap gap-4">
      <div class="font-lora font-medium text-xl md:text-2xl text-black">
        <a href="/" class="hover:opacity-70 transition-opacity">Сергей Хабаров</a>
      </div>
      <nav class="flex items-center gap-6 md:gap-10 flex-wrap">
        <a href="/" class="text-[#888888] text-[13px] hover:text-black transition-colors">Главная</a>
        <a href="/blog/" class="text-[#888888] text-[13px] hover:text-black transition-colors">Блог</a>
        <a href="/#contact" class="bg-[--color-primary] text-white text-[13px] font-medium px-6 py-2.5 rounded-3xl hover:opacity-90 transition-opacity">
          <h2 class="font-lora text-2xl font-medium text-black group-hover:opacity-70 transition-opacity">Написать</h2>
        </a>
      </nav>
    </div>
  </header>

  <!-- Article Content -->
  <main>
    <!-- Fullscreen Hero Header -->
    {post.data.heroImage && post.data.heroLayout === "fullscreen" && (
      <div class="relative w-full h-screen md:h-[80vh] lg:h-screen overflow-hidden">
        <!-- Fixed Background Image -->
        <div 
          class="absolute inset-0 bg-cover bg-center bg-fixed"
          style={`background-image: url('${post.data.heroImage}')`}
        />
        
        <!-- Color Overlay -->
        <div class="absolute inset-0 bg-orange-600 opacity-80 mix-blend-multiply"></div>
        
        <!-- Content Overlay -->
        <div class="relative z-10 h-full flex items-center justify-center">
          <div class="text-center text-white px-4 max-w-4xl mx-auto">
            <!-- Category and Type -->
            <div class="flex items-center justify-center gap-4 flex-wrap mb-6">
              <a href={`/categories/${categorySlug}`} class="bg-white/20 backdrop-blur-sm text-white text-[12px] font-medium px-4 py-2 rounded-full hover:bg-white/30 transition-colors">
                {post.data.category}
              </a>
              <span class="bg-white/20 backdrop-blur-sm text-white text-[12px] font-medium px-4 py-2 rounded-full">
                {post.data.type}
              </span>
            </div>

            <!-- Title -->
            <h1 class="font-medium text-4xl md:text-5xl lg:text-6xl xl:text-7xl leading-[1.1] text-white mb-6" style="font-family: 'Lora', serif">
              {post.data.title}
            </h1>

            <!-- Description -->
            <p class="text-lg md:text-xl lg:text-2xl text-white/90 mb-8 max-w-3xl mx-auto">
              {post.data.description}
            </p>

            <!-- Meta -->
            <div class="flex flex-col items-center gap-2">
              <time class="text-white/80 text-sm">
                {post.data.date.toLocaleDateString('ru-RU', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                })}
              </time>
              
              {post.data.tags.length > 0 && (
                <div class="flex flex-wrap justify-center gap-2">
                  {post.data.tags.map((tag: string) => (
                    <a 
                      href={`/tags/${getTagSlug(tag)}`} 
                      class="bg-white/10 backdrop-blur-sm text-white/80 text-[11px] px-3 py-1 rounded-full hover:bg-white/20 transition-colors"
                    >
                      #{tag}
                    </a>
                  ))}
                </div>
              )}
            </div>
          </div>
        </div>
      </div>
    )}

    <!-- Article Body -->
    <div class="bg-white">
      <article class="max-w-[1440px] mx-auto px-4 md:px-8 lg:px-30 py-12 md:py-16 lg:py-20">
        <!-- Standard Header for posts without fullscreen hero or regular hero image -->
        {(!post.data.heroLayout || post.data.heroLayout !== "fullscreen") && (
          <div class="flex flex-col gap-6 mb-12">
            <!-- Regular Hero Image (not fullscreen) -->
            {post.data.heroImage && (
              <div class="w-full aspect-video md:aspect-[2/1] lg:aspect-[3/1] overflow-hidden rounded-lg">
                <img 
                  src={post.data.heroImage} 
                  alt={post.data.heroAlt || post.data.title}
                  class="w-full h-full object-cover"
                />
              </div>
            )}
            
            <div class="flex items-center gap-4 flex-wrap">
              <a href={`/categories/${categorySlug}`} class="bg-[--color-accent-green] text-black text-[12px] font-medium px-4 py-2 rounded-full hover:opacity-80 transition-opacity">
                {post.data.category}
              </a>
              <span class="bg-[--color-primary] text-white text-[12px] font-medium px-4 py-2 rounded-full">
                {post.data.type}
              </span>
            </div>

            <h1 class="font-medium text-4xl md:text-5xl lg:text-[64px] leading-[1.1] text-black" style="font-family: 'Lora', serif">
              {post.data.title}
            </h1>

            <div class="flex flex-col gap-2">
              <time class="text-[#888888] text-[13px] font-medium">
                {post.data.date.toLocaleDateString('ru-RU', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                })}
              </time>
              
              {post.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-2">
                  {post.data.tags.map((tag: string) => (
                    <a 
                      href={`/tags/${getTagSlug(tag)}`} 
                      class="bg-[#F5F5F5] text-[#666666] text-[12px] px-3 py-1 rounded-full hover:bg-[--color-accent-green] hover:text-white transition-colors"
                    >
                      #{tag}
                    </a>
                  ))}
                </div>
              )}
            </div>
          </div>
        )}

        <!-- Article Content -->
        <div class="prose prose-lg max-w-none">
          <Content components={{ 
            TwoColumns, 
            ImageWide, 
            Callout, 
            HeroImage, 
            VideoEmbed, 
            QuoteBlock, 
            StatsGrid, 
            LinkList, 
            BookCard,
            PostHeader,
            Calendar 
          }} />
        </div>

        <!-- Related Posts -->
        <RelatedPosts relatedSlugs={post.data.relatedPosts} />
      </article>
    </div>
  </main>

  <!-- Footer -->
  <footer class="bg-[#1A1A1A]">
    <div class="max-w-[1440px] mx-auto px-4 md:px-8 lg:px-30 py-12 md:py-15">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <p class="text-[#666666] text-[13px]">2006—2026</p>
        <p class="text-[#666666] text-[13px]">Ереван</p>
      </div>
    </div>
  </footer>
</Layout>

<style>
  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .prose {
    animation: slideUp 0.6s ease-out 0.3s both;
  }

  .prose :global(p),
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(ul),
  .prose :global(ol) {
    animation: slideUp 0.4s ease-out both;
    animation-delay: calc(0.5s + var(--index, 0) * 0.05s);
  }

  .prose :global(h1),
  .prose h1 {
    font-family: 'Lora', serif !important;
    font-weight: 500;
    font-size: 1.875rem;
    line-height: 2.25rem;
    color: black;
    margin-bottom: 2rem;
  }

  @media (min-width: 768px) {
    .prose :global(h1),
    .prose h1 {
      font-size: 2.25rem;
      line-height: 2.5rem;
    }
  }

  .prose :global(h2),
  .prose h2 {
    font-family: 'Lora', serif !important;
    font-weight: 500;
    font-size: 1.5rem;
    line-height: 2rem;
    color: black;
    margin-top: 3rem;
    margin-bottom: 1.5rem;
  }

  @media (min-width: 768px) {
    .prose :global(h2),
    .prose h2 {
      font-size: 1.875rem;
      line-height: 2.25rem;
    }
  }

  .prose :global(h3),
  .prose h3 {
    font-family: 'Lora', serif !important;
    font-weight: 500;
    font-size: 1.25rem;
    line-height: 1.75rem;
    color: black;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  @media (min-width: 768px) {
    .prose :global(h3),
    .prose h3 {
      font-size: 1.5rem;
      line-height: 2rem;
    }
  }

  .prose :global(p) {
    color: #666666;
    font-size: 1.125rem;
    line-height: 1.625;
    margin-bottom: 1.5rem;
  }

  .prose :global(a) {
    color: var(--color-primary);
    opacity: 1;
    transition: opacity 0.2s;
    position: relative;
  }

  .prose :global(a:hover) {
    opacity: 0.7;
  }

  .prose :global(ul) {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .prose :global(ol) {
    list-style-type: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .prose :global(li) {
    color: #666666;
    font-size: 1.125rem;
    line-height: 1.625;
    margin-bottom: 0.5rem;
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--color-accent-green);
    padding-left: 1.5rem;
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
    margin-bottom: 1.5rem;
    background-color: #FAFAFA;
    border-radius: 0 0.375rem 0.375rem 0;
  }

  .prose :global(code) {
    background-color: #f3f4f6;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Consolas, "Liberation Mono", Menlo, monospace;
  }

  .prose :global(pre) {
    background-color: #111827;
    color: #f9fafb;
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .prose :global(img) {
    width: 100%;
    border-radius: 0.5rem;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    margin-top: 2rem;
    margin-bottom: 2rem;
  }
</style>
