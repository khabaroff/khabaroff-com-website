---
import { getCollection } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { getTagSlug } from '../../utils/tags';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const posts = allPosts.filter(post => !post.data.draft);

  const uniqueTags = [...new Set(posts.flatMap(post => post.data.tags))];

  const tagMap = new Map<string, string>();
  uniqueTags.forEach(tag => {
    tagMap.set(getTagSlug(tag), tag);
  });

  return Array.from(tagMap.entries()).map(([slug, originalTag]) => ({
    params: { tag: slug },
    props: {
      tag: originalTag,
      posts: posts
        .filter(post => post.data.tags.includes(originalTag))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    },
  }));
}

const { tag, posts } = Astro.props;
---

<PostLayout title={`Посты с тегом: ${tag}`}>
  <main class="tag-page">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Главная</a>
        <span>/</span>
        <a href="/blog/">Блог</a>
        <span>/</span>
        <span class="current">#{tag}</span>
      </nav>

      <div class="tag-header">
        <h1 class="tag-title">
          Посты с тегом: <span class="tag-accent">#{tag}</span>
        </h1>
        <p class="tag-count">
          {posts.length} {posts.length === 1 ? 'пост' : posts.length < 5 ? 'поста' : 'постов'} с этим тегом
        </p>
      </div>

      {posts.length === 0 ? (
        <div class="empty">
          <p>Постов с этим тегом пока нет.</p>
        </div>
      ) : (
        <div class="posts-grid">
          {posts.map(post => (
            <article class="post-card">
              <time class="post-date">
                {post.data.date.toLocaleDateString('ru-RU', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                })}
              </time>

              <h2 class="post-title">
                <a href={`/${post.slug}/`}>{post.data.title}</a>
              </h2>

              {post.data.description && (
                <p class="post-desc">{post.data.description}</p>
              )}

              {post.data.tags && post.data.tags.length > 0 && (
                <div class="post-tags">
                  {post.data.tags.map((postTag: string) => (
                    <a
                      href={`/tags/${getTagSlug(postTag)}/`}
                      class:list={['tag-link', { 'tag-link--active': postTag === tag }]}
                    >
                      #{postTag}
                    </a>
                  ))}
                </div>
              )}

              <a href={`/${post.slug}/`} class="post-read">→ Читать далее</a>
            </article>
          ))}
        </div>
      )}
    </div>
  </main>
</PostLayout>

<style>
  .tag-page {
    background: var(--color-white);
    padding: 48px 0 80px;
  }
  @media (min-width: 768px) { .tag-page { padding: 64px 0 80px; } }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    margin-bottom: 24px;
  }
  .breadcrumb a {
    color: var(--color-text-muted);
    transition: color 0.2s;
  }
  .breadcrumb a:hover { color: var(--color-text); }
  .breadcrumb span { color: var(--color-text-muted); }
  .breadcrumb .current { color: var(--color-text); font-weight: 500; }
  .tag-header { margin-bottom: 48px; }
  .tag-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 30px;
    line-height: 1.1;
    color: var(--color-text);
    margin-bottom: 8px;
  }
  @media (min-width: 768px) { .tag-title { font-size: 36px; } }
  @media (min-width: 1024px) { .tag-title { font-size: 48px; } }
  .tag-accent { color: var(--color-accent-green); }
  .tag-count { color: var(--color-text-secondary); font-size: 18px; }
  .empty { text-align: center; padding: 48px 0; }
  .empty p { color: var(--color-text-secondary); font-size: 18px; }
  .posts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }
  @media (min-width: 768px) { .posts-grid { grid-template-columns: 1fr 1fr; gap: 48px; } }
  .post-card { display: flex; flex-direction: column; gap: 8px; }
  .post-date { color: var(--color-text-muted); font-size: 13px; font-weight: 500; }
  .post-title {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.3;
  }
  .post-title a { transition: opacity 0.2s; }
  .post-title a:hover { opacity: 0.7; }
  .post-desc {
    color: var(--color-text-secondary);
    font-size: 16px;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-tags { display: flex; flex-wrap: wrap; gap: 8px; padding-top: 8px; }
  .tag-link {
    background: var(--color-background-alt);
    color: var(--color-text-secondary);
    font-size: 12px;
    padding: 4px 12px;
    border-radius: 20px;
    transition: all 0.2s;
  }
  .tag-link:hover, .tag-link--active {
    background: var(--color-accent-green);
    color: white;
  }
  .post-read {
    color: var(--color-text);
    font-weight: 500;
    font-size: 13px;
    transition: opacity 0.2s;
    margin-top: 8px;
  }
  .post-read:hover { opacity: 0.7; }
</style>
