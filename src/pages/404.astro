---
import PostLayout from '../layouts/PostLayout.astro';
---

<PostLayout title="Страница не найдена">
  <main class="error-page">
    <div class="container">
      <h1 class="error-code">404</h1>
      <p class="error-text">Страница не найдена</p>
      <a href="/" class="error-link">← На главную</a>
    </div>
  </main>
</PostLayout>

<style>
  .error-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
  }
  .error-code {
    font-family: var(--font-display);
    font-size: 120px;
    font-weight: 500;
    color: var(--color-border);
    line-height: 1;
    margin-bottom: 16px;
  }
  .error-text {
    color: var(--color-text-secondary);
    font-size: 20px;
    margin-bottom: 32px;
  }
  .error-link {
    color: var(--color-primary);
    font-weight: 500;
    font-size: 16px;
    transition: opacity 0.2s;
  }
  .error-link:hover { opacity: 0.7; }
</style>
