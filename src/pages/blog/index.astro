---
import { getCollection } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { getTagSlug } from '../../utils/tags';

const allPosts = await getCollection('posts');
const posts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<PostLayout title="Блог" description="Лонгриды о системах, мышлении и работе">
  <main class="blog-page">
    <div class="container">
      <div class="blog-header">
        <p class="blog-label">Блог</p>
        <h1 class="blog-title">Лонгриды о системах, мышлении и работе</h1>
        <p class="blog-desc">
          Заметки, рефлексии и наблюдения. Пишу о том, как выстраивать процессы,
          развивать мышление и эффективно работать с технологиями.
        </p>
      </div>

      {posts.length === 0 ? (
        <div class="empty">
          <p>Постов пока нет.</p>
        </div>
      ) : (
        <div class="posts-grid">
          {posts.map(post => (
            <article class="post-card">
              <time class="post-date">
                {post.data.date.toLocaleDateString('ru-RU', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                })}
              </time>

              <h2 class="post-title">
                <a href={`/${post.slug}/`}>{post.data.title}</a>
              </h2>

              {post.data.description && (
                <p class="post-desc">{post.data.description}</p>
              )}

              {post.data.tags && post.data.tags.length > 0 && (
                <div class="post-tags">
                  {post.data.tags.map((tag: string) => (
                    <a href={`/tags/${getTagSlug(tag)}/`} class="tag">{tag}</a>
                  ))}
                </div>
              )}

              <a href={`/${post.slug}/`} class="post-read">→ Читать далее</a>
            </article>
          ))}
        </div>
      )}
    </div>
  </main>
</PostLayout>

<style>
  .blog-page {
    background: var(--color-white);
    padding: 48px 0 80px;
  }
  @media (min-width: 768px) { .blog-page { padding: 64px 0 80px; } }
  .blog-header { margin-bottom: 48px; }
  .blog-label {
    color: var(--color-text-muted);
    font-size: 13px;
    font-weight: 500;
    margin-bottom: 16px;
  }
  .blog-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 30px;
    line-height: 1.1;
    color: var(--color-text);
    margin-bottom: 16px;
  }
  @media (min-width: 768px) { .blog-title { font-size: 36px; } }
  @media (min-width: 1024px) { .blog-title { font-size: 48px; } }
  .blog-desc {
    color: var(--color-text-secondary);
    font-size: 18px;
    line-height: 1.6;
    max-width: 700px;
  }
  .empty {
    text-align: center;
    padding: 48px 0;
  }
  .empty p { color: var(--color-text-secondary); font-size: 18px; }
  .posts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }
  @media (min-width: 768px) { .posts-grid { grid-template-columns: 1fr 1fr; gap: 48px; } }
  .post-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .post-date {
    color: var(--color-text-muted);
    font-size: 13px;
    font-weight: 500;
  }
  .post-title {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.3;
  }
  .post-title a { transition: opacity 0.2s; }
  .post-title a:hover { opacity: 0.7; }
  .post-desc {
    color: var(--color-text-secondary);
    font-size: 16px;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding-top: 8px;
  }
  .tag {
    background: var(--color-background-alt);
    color: var(--color-text-secondary);
    font-size: 12px;
    padding: 4px 12px;
    border-radius: 20px;
    transition: all 0.2s;
  }
  .tag:hover {
    background: var(--color-accent-green);
    color: white;
  }
  .post-read {
    color: var(--color-text);
    font-weight: 500;
    font-size: 13px;
    transition: opacity 0.2s;
    margin-top: 8px;
  }
  .post-read:hover { opacity: 0.7; }
</style>
