---
import { getCollection } from 'astro:content';

interface Props {
  relatedSlugs: string[];
}

const { relatedSlugs } = Astro.props;

if (!relatedSlugs || relatedSlugs.length === 0) {
  return null;
}

const allPosts = await getCollection('posts');
const relatedPosts = allPosts.filter(post =>
  relatedSlugs.includes(post.slug) && !post.data.draft
);

if (relatedPosts.length === 0) {
  return null;
}
---

<section class="related-posts">
  <h3>Читайте также</h3>
  <ul>
    {relatedPosts.map(post => (
      <li>
        <a href={`/${post.slug}/`}>
          <h4>{post.data.title}</h4>
          {post.data.description && (
            <p>{post.data.description}</p>
          )}
          <div class="post-meta">
            <span class="post-type">{post.data.type}</span>
            <span class="post-category">{post.data.category}</span>
          </div>
        </a>
      </li>
    ))}
  </ul>
</section>

<style>
  .related-posts {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 2px solid var(--color-pink);
  }

  .related-posts h3 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .related-posts ul {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .related-posts li {
    border: 1px solid #f0f0f0;
    border-radius: 8px;
    padding: 1.5rem;
    transition: border-color 0.2s;
  }

  .related-posts li:hover {
    border-color: var(--color-pink);
  }

  .related-posts a {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .related-posts h4 {
    font-family: var(--font-lora);
    color: var(--color-pink);
    margin: 0 0 0.5rem 0;
    font-size: 1.2rem;
    font-weight: 500;
  }

  .related-posts p {
    margin: 0.5rem 0;
    color: #666;
    font-size: 0.95rem;
  }

  .post-meta {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .post-type,
  .post-category {
    font-size: 0.75rem;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-weight: 500;
  }

  .post-type {
    background: var(--color-pink);
    color: white;
  }

  .post-category {
    background: #f0f0f0;
    color: #666;
  }
</style>
