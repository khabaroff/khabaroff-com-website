---
interface Props {
  type?: 'info' | 'warning' | 'success';
}

const { type = 'info' } = Astro.props;
---

<div class:list={['callout', `callout--${type}`]}>
  <slot />
</div>

<style>
  .callout {
    padding: 16px 20px;
    border-left: 4px solid;
    border-radius: 0 6px 6px 0;
    margin: 24px 0;
  }
  .callout--info {
    background: #eff6ff;
    border-color: #60a5fa;
    color: #1e40af;
  }
  .callout--warning {
    background: #fffbeb;
    border-color: #fbbf24;
    color: #92400e;
  }
  .callout--success {
    background: #f0fdf4;
    border-color: #4ade80;
    color: #166534;
  }
</style>
